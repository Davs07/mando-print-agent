{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "out/renderer",
    "rootDir": ".",
    "jsx": "react-jsx",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["ui/**/*", "electron/ipc-types.ts"],
  "exclude": ["node_modules", "dist", "out", "src"]
}
