# ─────────────────────────────────────────────
# Mando Print Agent — configuración
# Copiar a .env y rellenar con los valores reales
# ─────────────────────────────────────────────

# Token del agente obtenido al crearlo en el panel (obligatorio)
MANDO_AGENT_TOKEN=mpag_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL del backend de Mando (sin barra final) (obligatorio)
MANDO_BACKEND_URL=https://api.tudominio.com

# ─── Tipo de impresora ───────────────────────
# Opciones: network | serial | file
PRINTER_TYPE=network

# network → impresora Ethernet/WiFi via TCP port 9100
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100

# serial → impresora USB que aparece como puerto serie
# PRINTER_TYPE=serial
# SERIAL_PATH=COM3          (Windows) o /dev/usb/lp0 (Linux)
# SERIAL_BAUD_RATE=9600

# file → escribe los bytes en un archivo (útil para pruebas)
# PRINTER_TYPE=file
# PRINTER_FILE_PATH=/tmp/printer.bin

# ─── Configuración general ───────────────────
# Ancho de papel por defecto si el job no especifica
PAPER_WIDTH=80mm

# Intervalo de heartbeat en ms (recomendado: 25000)
HEARTBEAT_INTERVAL_MS=25000

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info
