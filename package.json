{
  "name": "mando-print-agent",
  "version": "1.0.0",
  "description": "Agente local de impresión para Mando Platform — conecta la nube con impresoras térmicas físicas",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:once": "ts-node --transpile-only src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@point-of-sale/receipt-printer-encoder": "^3.0.0",
    "dotenv": "^16.4.5",
    "socket.io-client": "^4.8.1"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
