{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "out",
    "rootDir": ".",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["electron/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist", "out", "ui"]
}
